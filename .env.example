# Admin panel (optional - defaults: admin / admin123)
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=admin123

# EmailJS - get keys from https://www.emailjs.com/
# Create a template with variables: to_email, from_name, from_phone, from_email, message
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
